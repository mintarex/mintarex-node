{
  "name": "@mintarex-official/node",
  "version": "0.0.6",
  "description": "Official Node.js SDK for the Mintarex Corporate OTC API",
  "keywords": [
    "mintarex",
    "otc",
    "crypto",
    "trading",
    "api",
    "sdk"
  ],
  "homepage": "https://developers.mintarex.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mintarex/mintarex-node.git"
  },
  "bugs": {
    "url": "https://github.com/mintarex/mintarex-node/issues"
  },
  "license": "MIT",
  "author": "Mintarex",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-test-coverage test/*.test.js",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.0"
  }
}
